# Copy to .env and fill in real values before running
DATABASE_URL=postgresql://flowcheck_user:CHANGEME@127.0.0.1:5432/flowcheck_db

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGEME

# StreamflowOps API
DATAOPS_API_URL=https://streamflowops.3rdplaces.io
DATAOPS_API_TOKEN=CHANGEME

# Path to Firebase service account JSON (download from Firebase console > Project Settings > Service accounts)
FIREBASE_CREDENTIALS_PATH=/home/geoskimoto/projects/flowcheck-api/firebase-credentials.json
